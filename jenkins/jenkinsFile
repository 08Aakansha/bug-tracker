pipeline {
    agent any

    stages {
        stage('Unit Test - Backend') {
            agent { 
                docker {
                    image 'golang:1.21'
                    reuseNode true
                }
            }
            environment {
                GOCACHE = "${WORKSPACE}/.cache"
            }
            steps {
                dir('bugtracker-backend') { 
                    sh 'mkdir -p $GOCACHE'
                    sh 'go test -v ./...'
                }
            }
        }

        stage('Unit Test - Frontend') {
            agent { 
                docker {
                    image 'node:20-alpine'
                    reuseNode true
                }
            }
            steps {
                dir('bugtracker-frontend') { 
                    sh '''
                      npm ci
                      npm test
                      mkdir -p reports
                      mv coverage reports/
                      '''
                }
            }
        } // End of Frontend Stage
    } // End of Stages

    post {
        always {
            junit 'bugtracker-frontend/test-results.xml'
            publishHTML target: [
                reportDir: 'bugtracker-frontend/reports/coverage',
                reportFiles: 'index.html',
                reportName:  'Frontend Coverage Report'
            ]
        }
    }
} // End of Pipeline