pipeline {
    agent any

    stages {
        stage('Unit Test - Backend') {
            agent { 
                docker {
                    image 'golang:1.21'
                    reuseNode true
                }
            }
            environment {
                GOCACHE = "${WORKSPACE}/.cache"
            }
            steps {
                dir('bugtracker-backend') { 
                    sh 'mkdir -p $GOCACHE'
                    sh 'go test -v ./...'
                }
            }
        }
    }
}