pipeline {
    agent any

    stages {
        stage('Unit Test - Backend') {
            agent { 
                docker {
                    image 'golang:1.21'
                    reuseNode true
                    // This argument helps if Jenkins is running in a container
                    args '-v /var/run/docker.sock:/var/run/docker.sock' 
                }
            }
            environment {
                GOCACHE = "${WORKSPACE}/.cache"
            }
            steps {
                dir('bugtracker-backend') { 
                    sh 'mkdir -p $GOCACHE'
                    sh 'go test -v ./...'
                }
            }
        }

        stage('Unit Test - Frontend') {
            agent { 
                docker {
                    image 'node:20-alpine'
                    reuseNode true
                }
            }
            steps {
                dir('bugtracker-frontend') { 
                    sh '''
                      npm ci
                      npm test
                      mkdir -p reports
                      mv coverage reports/ || true
                      '''
                }
            }
        }
    }

    post {
        // Change 'always' to 'success' to avoid errors when stages are skipped
        success {
            junit 'bugtracker-frontend/test-results.xml'
            publishHTML target: [
                allowMissing: true, // Prevents failure if tests didn't run
                reportDir: 'bugtracker-frontend/reports/coverage',
                reportFiles: 'index.html',
                reportName:  'Frontend Coverage Report'
            ]
        }
    }
}