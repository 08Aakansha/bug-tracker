pipeline {
    agent any

    environment {
        // Must match the alias 'docker' in your compose file
        DOCKER_HOST = "tcp://docker:2376"
        DOCKER_CERT_PATH = "/certs/client"
        DOCKER_TLS_VERIFY = "1"
        
        // Pass these down to the dynamic containers created by Jenkins
        DOCKER_ARGS = "-e DOCKER_HOST=tcp://docker:2376 -e DOCKER_TLS_VERIFY=1 -e DOCKER_CERT_PATH=/certs/client -v jenkins-docker-certs:/certs/client:ro"
    }

    stages {
        stage('Unit Test - Backend') {
            agent { 
                docker {
                    image 'golang:1.21'
                    reuseNode true
                    args "${env.DOCKER_ARGS}"
                }
            }
            steps {
                dir('bugtracker-backend') { 
                    sh 'go test -v ./...'
                }
            }
        }

        stage('Unit Test - Frontend') {
            agent { 
                docker {
                    image 'node:20-alpine'
                    reuseNode true
                    args "${env.DOCKER_ARGS}"
                }
            }
            steps {
                dir('bugtracker-frontend') { 
                    sh '''
                        npm ci
                        npm test || true
                        mkdir -p reports
                        [ -d "coverage" ] && cp -r coverage reports/ || echo "Coverage skip"
                    '''
                }
            }
        }
    }

    post {
        always {
            script {
                if (fileExists('bugtracker-frontend/test-results.xml')) {
                    junit 'bugtracker-frontend/test-results.xml'
                }
            }
            publishHTML(target: [
                allowMissing: true,
                reportDir: 'bugtracker-frontend/reports/coverage',
                reportFiles: 'index.html',
                reportName: 'Frontend Coverage Report'
            ])
        }
    }
}