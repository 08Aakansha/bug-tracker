pipeline {
    agent any

    stages {
        stage('Unit Test - Backend') {
            agent { 
                docker {
                    image 'golang:1.21'
                    reuseNode true
                }
            }
            environment {
                GOCACHE = "${WORKSPACE}/.cache"
            }
            steps {
                dir('bugtracker-backend') { 
                    sh 'mkdir -p $GOCACHE'
                    sh 'go test -v ./...'
                }
            }
        }
          stage('Unit Test - Frontend') {
            agent { 
                docker {
                    image 'node:20-alpine'
                    reuseNode true
                }
            }

            steps {
                dir('bugtracker-frontend') { 
                    sh '''
                      npm ci
                      npm test
                      '''
                }
            }
        }

        
    }
}